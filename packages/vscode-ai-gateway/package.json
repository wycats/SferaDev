{
  "name": "vscode-ai-gateway",
  "private": true,
  "displayName": "Vercel AI",
  "description": "VS Code extension that provides Vercel AI models via the Language Model API",
  "version": "0.3.0",
  "publisher": "vercel",
  "license": "MIT",
  "icon": "images/icon.png",
  "type": "module",
  "engines": {
    "vscode": "^1.108.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "ai",
    "vercel",
    "chat",
    "gpt",
    "claude",
    "gemini",
    "llm",
    "tools"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vercel-labs/vscode-ai-gateway"
  },
  "homepage": "https://github.com/vercel-labs/vscode-ai-gateway#readme",
  "bugs": {
    "url": "https://github.com/vercel-labs/vscode-ai-gateway/issues"
  },
  "main": "./out/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "vercel",
        "displayName": "Vercel AI"
      }
    ],
    "chatParticipants": [
      {
        "id": "vercel.ai.chat",
        "name": "vercel",
        "description": "Chat using Vercel AI Gateway models",
        "commands": []
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vercel-ai",
          "title": "AI Gateway",
          "icon": "images/icon.svg"
        }
      ]
    },
    "views": {
      "vercel-ai": [
        {
          "id": "vercel.ai.agentTree",
          "name": "Agent Tokens",
          "contextualTitle": "Agent Token Usage",
          "visibility": "visible",
          "when": "config.vercel.ai.experimental.agentTree"
        }
      ]
    },
    "commands": [
      {
        "command": "vercel.ai.manage",
        "title": "Manage Authentication",
        "category": "Vercel AI Gateway"
      },
      {
        "command": "vercel.ai.showTokenDetails",
        "title": "Show Token Usage Details",
        "category": "Vercel AI Gateway"
      },
      {
        "command": "vercel.ai.refreshAgentTree",
        "title": "Refresh Agent Tree",
        "category": "Vercel AI Gateway",
        "icon": "$(refresh)"
      },
      {
        "command": "vercel.ai.inspectNode",
        "title": "Inspect",
        "category": "Vercel AI Gateway"
      },
      {
        "command": "vercel.ai.inspectNodeNewWindow",
        "title": "Inspect in New Window",
        "category": "Vercel AI Gateway"
      },
      {
        "command": "vercel.ai.dumpDiagnostics",
        "title": "Dump Agent Tree Diagnostics",
        "category": "Vercel AI Gateway"
      },
      {
        "command": "vercel.ai.testSummarizationDetection",
        "title": "Test Summarization Detection",
        "category": "Vercel AI Gateway"
      },
      {
        "command": "vercel.ai.enableDebugLogging",
        "title": "Enable Debug Logging (for Bug Reports)",
        "category": "Vercel AI Gateway"
      },
      {
        "command": "vercel.ai.disableDebugLogging",
        "title": "Disable Debug Logging",
        "category": "Vercel AI Gateway"
      },
      {
        "command": "vercel.ai.exportLogs",
        "title": "Export Logs for Bug Report",
        "category": "Vercel AI Gateway"
      },
      {
        "command": "vercel.ai.investigation.prune",
        "title": "Prune Investigation Logs",
        "category": "Vercel AI Gateway"
      },
      {
        "command": "vercel.ai.exportErrorLogs",
        "title": "Export Error Logs Only",
        "category": "Vercel AI Gateway"
      },
      {
        "command": "vercel.ai.refreshModels",
        "title": "Refresh Models",
        "category": "Vercel AI Gateway"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "vercel.ai.refreshAgentTree",
          "when": "view == vercel.ai.agentTree",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "vercel.ai.inspectNode",
          "when": "view == vercel.ai.agentTree && viewItem =~ /inspectable/",
          "group": "inline"
        },
        {
          "command": "vercel.ai.inspectNodeNewWindow",
          "when": "view == vercel.ai.agentTree && viewItem =~ /inspectable/",
          "group": "inspect"
        }
      ]
    },
    "configuration": {
      "title": "Vercel AI Gateway",
      "properties": {
        "vercel.ai.endpoint": {
          "type": "string",
          "default": "https://ai-gateway.vercel.sh",
          "description": "AI Gateway endpoint URL. Change for self-hosted or regional deployments."
        },
        "vercel.ai.models.default": {
          "type": "string",
          "default": "",
          "description": "Default model ID (e.g., 'anthropic/claude-sonnet-4-20250514'). Leave empty to show model picker."
        },
        "vercel.ai.logging.level": {
          "type": "string",
          "enum": [
            "off",
            "error",
            "warn",
            "info",
            "debug",
            "trace"
          ],
          "default": "warn",
          "description": "Output channel logging verbosity.",
          "enumDescriptions": [
            "Disable all logging",
            "Log only errors",
            "Log errors and warnings",
            "Log errors, warnings, and info messages",
            "Log everything including debug messages",
            "Log everything including trace-level diagnostic messages"
          ]
        },
        "vercel.ai.logging.fileLevel": {
          "type": "string",
          "enum": [
            "off",
            "error",
            "warn",
            "info",
            "debug",
            "trace"
          ],
          "default": "off",
          "description": "Default file logging level for all event categories. Events are written to .logs/{investigation}/events.jsonl. Individual categories can override this via 'logging.categories'.",
          "enumDescriptions": [
            "Disable file logging (default)",
            "Log only errors to file",
            "Log errors and warnings to file",
            "Log errors, warnings, and info to file",
            "Log everything including debug to file",
            "Log everything including trace-level to file"
          ]
        },
        "vercel.ai.logging.categories": {
          "type": "object",
          "default": {},
          "description": "Per-category file logging level overrides. Categories: 'requests' (API calls), 'tree' (conversation tree changes), 'agents' (agent lifecycle), 'session' (extension lifecycle). Set a category to a level to override the default fileLevel.",
          "additionalProperties": {
            "type": "string",
            "enum": [
              "off",
              "error",
              "warn",
              "info",
              "debug",
              "trace"
            ]
          }
        },
        "vercel.ai.models.showAll": {
          "type": "boolean",
          "default": false,
          "description": "Show all available models in the chat model picker. When disabled (default), models are hidden until you enable them via the 'Manage Models' dropdown."
        },
        "vercel.ai.logging.fileDirectory": {
          "type": "string",
          "default": ".logs",
          "description": "Directory for file-based logs. Relative paths resolve against the first workspace folder. Absolute paths are used as-is."
        },
        "vercel.ai.logging.name": {
          "type": "string",
          "default": "default",
          "description": "Log scope name. File logs are written to {fileDirectory}/{name}/. Change the name to start a clean log scope."
        },
        "vercel.ai.logging.granularity": {
          "type": "string",
          "enum": [
            "off",
            "index",
            "messages",
            "full"
          ],
          "default": "index",
          "description": "Request event granularity when file logging is enabled. Controls how much detail is captured for each API request.",
          "enumDescriptions": [
            "Disable request detail logging (only category-level events are written)",
            "Log index entries only (one line per request with timing, token counts, status)",
            "Log index + per-conversation message summaries + full request/response bodies",
            "Log everything including raw SSE event streams"
          ]
        },
        "vercel.ai.experimental.agentTree": {
          "type": "boolean",
          "default": false,
          "description": "Enable the Agent Tokens sidebar view (experimental). Shows token usage per conversation in a tree view."
        }
      }
    }
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "node scripts/build.mjs --watch",
    "compile": "tsc -p ./",
    "tsc": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "pnpm build && pnpm exec tsc -p tsconfig.test.json && node scripts/test-integration.js",
    "test:integration:headed": "pnpm build && pnpm exec tsc -p tsconfig.test.json && node scripts/test-integration.js --headed",
    "test:watch": "vitest",
    "analyze:logs": "node ../../packages/agent-cli/src/query-events.ts",
    "clean": "rm -rf out",
    "prepackage": "pnpm run build",
    "package": "vsce package --no-dependencies",
    "release": "pnpm run package && vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@types/json-schema": "catalog:",
    "@types/mocha": "^10.0.6",
    "@types/node": "catalog:",
    "@types/vscode": "^1.108.1",
    "@vercel/tsconfig": "workspace:*",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "catalog:",
    "dotenv": "^17.2.3",
    "esbuild": "^0.24.0",
    "eslint-interactive": "^12.0.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "vite": "catalog:",
    "fast-check": "catalog:",
    "glob": "^10.4.5",
    "mocha": "^10.8.2",
    "svelte": "^5.51.3",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  },
  "dependencies": {
    "@shikijs/langs": "^3.22.0",
    "@shikijs/themes": "^3.22.0",
    "@vercel/conversation": "workspace:*",
    "@vscode-elements/elements": "^2.5.0",
    "ai-tokenizer": "^1.0.6",
    "marked": "^17.0.3",
    "openresponses-client": "workspace:*",
    "safe-stable-stringify": "^2.5.0",
    "shiki": "^3.22.0"
  }
}
