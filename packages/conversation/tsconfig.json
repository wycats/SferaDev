{
  "extends": "@vercel/tsconfig/base.json",
  "compilerOptions": {
    "lib": ["ES2024"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2024",
    "rootDir": "src",
    "outDir": "out",
    "noEmit": true,
    "allowImportingTsExtensions": true
  },
  "include": ["src"],
  "exclude": ["out", "node_modules"]
}
