{
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/node_modules": true,
    "**/out": true,
    "**/dist": true,
    "**/*.vsix": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/*.code-search": true
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/.hg/store/**": true,
    ".reference/**": true,
    ".logs/**": true
  },

  "vercel.ai.logging.fileDirectory": ".logs",
  "vercel.ai.logging.level": "debug",

  // Investigation logging — captures request/response data for debugging
  "vercel.ai.investigation.detail": "messages",
  "vercel.ai.investigation.name": "summ-debug"
}
