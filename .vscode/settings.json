{
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/node_modules": true,
    "**/out": true,
    "**/dist": true,
    "**/*.vsix": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/*.code-search": true,
    ".reference": true
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/.hg/store/**": true,
    ".reference/**": true,
    ".logs/**": true
  },

  "vercel.ai.logging.fileDirectory": ".logs",
  "vercel.ai.logging.level": "trace",

  // Forensic capture - capture full Copilot prompts for analysis
  "vercel.ai.debug.forensicCapture": true,
  "vercel.ai.debug.forensicCaptureFullContent": true
}
